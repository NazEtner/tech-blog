---
import type { CollectionEntry } from 'astro:content';
import { getPostHref } from '../utils/posts';

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, tags } = entry.data;
const href = getPostHref(entry);
const dateFormatter = new Intl.DateTimeFormat(entry.data.lang === 'ja' ? 'ja-JP' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="post-card">
  <p class="post-meta">{dateFormatter.format(pubDate)}</p>
  <h2><a href={href}>{title}</a></h2>
  <p>{description}</p>
  {tags.length > 0 && (
    <ul class="tag-list">
      {tags.map((t: string) => (
        <li><a href={`/blog/tags/${t}/`}>#{t}</a></li>
      ))}
    </ul>
  )}
</div>
