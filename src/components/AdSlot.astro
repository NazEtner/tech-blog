---
// Ad placement is intentionally manual/explicit (no Auto ads) so an ad unit
// can never land inside or immediately next to a code block. Callers place
// <AdSlot variant="in-article" /> etc. at deliberate points in PostLayout.
interface Props {
  variant: 'in-article' | 'end-of-article' | 'sidebar';
  slotId?: string;
}

const { variant, slotId } = Astro.props;
const adsenseClientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
const sidebarOnly = variant === 'sidebar';
---

{adsenseClientId && slotId ? (
  <div class:list={['ad-slot', `ad-slot--${variant}`, { 'ad-slot--sidebar': sidebarOnly }]}>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={adsenseClientId}
      data-ad-slot={slotId}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
) : (
  <div class:list={['ad-slot', `ad-slot--${variant}`, { 'ad-slot--sidebar': sidebarOnly }]}>
    広告枠（{variant}） — AdSense未設定
  </div>
)}

<style>
  .ad-slot--sidebar {
    display: none;
  }
  @media (min-width: 900px) {
    .ad-slot--sidebar {
      display: block;
    }
  }
</style>
