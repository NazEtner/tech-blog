---
import { getCollection } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import { getPostSlug, getPostHref } from '../../../utils/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', (p) => !p.data.draft);
  const enPosts = allPosts.filter((p) => p.data.lang === 'en');

  return enPosts.map((entry) => {
    const slug = getPostSlug(entry);
    const seriesEntries = entry.data.series
      ? allPosts.filter((p) => p.data.series?.slug === entry.data.series?.slug)
      : undefined;
    const jaCounterpart = allPosts.find(
      (p) => p.data.lang === 'ja' && getPostSlug(p) === slug
    );

    return {
      params: { slug },
      props: {
        entry,
        seriesEntries,
        langAlternateHref: jaCounterpart ? getPostHref(jaCounterpart) : undefined,
      },
    };
  });
}

const { entry, seriesEntries, langAlternateHref } = Astro.props;
const { headings, Content } = await entry.render();
---

<PostLayout entry={entry} headings={headings} seriesEntries={seriesEntries} langAlternateHref={langAlternateHref}>
  <Content />
</PostLayout>
