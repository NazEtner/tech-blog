---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  { href: '/blog/', label: 'Blog', desc: '技術ブログ。ゲームエンジン・ネットコード・レトロハードウェア・音声/MLツールなどの開発から面白かったものを書いています。' },
  { href: '/portfolio/', label: 'Portfolio', desc: '作ってきたものの紹介（準備中）。' },
  { href: '/about/', label: 'About', desc: 'このサイトについて。' },
];
---

<BaseLayout title="なななみの倉庫">
  <ul class="landing-links">
    {links.map((l) => (
      <li>
        <a href={l.href}>
          <h2>{l.label}</h2>
          <p>{l.desc}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .landing-links {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .landing-links a {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }
  .landing-links h2 {
    margin: 0 0 0.5rem 0;
    color: var(--color-accent);
  }
  .landing-links p {
    margin: 0;
    color: var(--color-muted);
  }
</style>
