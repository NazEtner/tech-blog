---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import SeriesNav from '../components/SeriesNav.astro';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: CollectionEntry<'posts'>;
  headings: Heading[];
  seriesEntries?: CollectionEntry<'posts'>[];
  langAlternateHref?: string;
}

const { entry, headings, seriesEntries, langAlternateHref } = Astro.props;
const { title, description, pubDate, updatedDate, tags, series, lang, sourceRepo } =
  entry.data;
const toc = headings.filter((h) => h.depth === 2);

const dateFormatter = new Intl.DateTimeFormat(lang === 'ja' ? 'ja-JP' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// When a translated counterpart exists, expose the ja/en pair (plus
// x-default pointing at the ja original) so search engines don't treat
// the two languages as duplicates.
const alternates = langAlternateHref
  ? [
      { hreflang: lang, href: Astro.url.pathname },
      { hreflang: lang === 'ja' ? 'en' : 'ja', href: langAlternateHref },
      {
        hreflang: 'x-default',
        href: lang === 'ja' ? Astro.url.pathname : langAlternateHref,
      },
    ]
  : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  inLanguage: lang,
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
  mainEntityOfPage: canonicalUrl.toString(),
  url: canonicalUrl.toString(),
  author: {
    '@type': 'Person',
    name: 'なななみ',
    url: new URL('/about/', Astro.site).toString(),
  },
  publisher: { '@type': 'Person', name: 'なななみ' },
  ...(series && { isPartOf: { '@type': 'CreativeWorkSeries', name: series.title } }),
};
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  ogType="article"
  ogImage={`/blog/og/${entry.slug}.png`}
  article={{ pubDate, updatedDate, tags }}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <article>
    <header>
      <p class="post-meta">
        {dateFormatter.format(pubDate)}
        {updatedDate && <> (更新: {dateFormatter.format(updatedDate)})</>}
      </p>
      <h1>{title}</h1>
      {tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((t: string) => (
            <li><a href={`/blog/tags/${t}/`}>#{t}</a></li>
          ))}
        </ul>
      )}
      {langAlternateHref && (
        <p><a href={langAlternateHref}>{lang === 'ja' ? 'Read in English' : '日本語で読む'}</a></p>
      )}
    </header>

    {toc.length > 1 && (
      <nav aria-label="table of contents">
        <strong>目次</strong>
        <ul>
          {toc.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </nav>
    )}

    <AdSlot variant="in-article" />

    <div class="post-content">
      <slot />
    </div>

    {sourceRepo && (
      <p class="post-meta">出典リポジトリ: <code>{sourceRepo}</code></p>
    )}

    {seriesEntries && series && (
      <SeriesNav seriesEntries={seriesEntries} currentSlug={entry.slug} seriesTitle={series.title} />
    )}

    <AdSlot variant="end-of-article" />
  </article>
</BaseLayout>
