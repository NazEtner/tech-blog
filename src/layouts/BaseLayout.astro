---
import '../styles/global.css';

interface Alternate {
  hreflang: string;
  href: string; // site-relative path
}

interface Props {
  title: string;
  description?: string;
  lang?: 'ja' | 'en';
  ogType?: 'website' | 'article';
  ogImage?: string; // site-relative path
  article?: {
    pubDate: Date;
    updatedDate?: Date;
    tags: string[];
  };
  alternates?: Alternate[];
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'いつものコードを、たまには読み物として。',
  lang = 'ja',
  ogType = 'website',
  ogImage = '/og-default.png',
  article,
  alternates,
  jsonLd,
} = Astro.props;

const siteTitle = 'なななみの倉庫';
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const ogLocale = lang === 'ja' ? 'ja_JP' : 'en_US';

// Left unset until AdSense approval; when set, BaseLayout loads the
// AdSense loader script once, site-wide.
const adsenseClientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternates?.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={new URL(alt.href, Astro.site)} />
    ))}

    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    {article && (
      <>
        <meta property="article:published_time" content={article.pubDate.toISOString()} />
        {article.updatedDate && (
          <meta property="article:modified_time" content={article.updatedDate.toISOString()} />
        )}
        {article.tags.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/blog/rss.xml" />
    {adsenseClientId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`}
        crossorigin="anonymous"
      ></script>
    )}
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/"><strong>{siteTitle}</strong></a>
        <div class="site-nav-links">
          <a href="/blog/">Blog</a>
          <a href="/portfolio/">Portfolio</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-nav">
        <span>&copy; {new Date().getFullYear()} {siteTitle}</span>
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/blog/rss.xml">RSS</a>
      </div>
    </footer>
  </body>
</html>
