---
import '../styles/global.css';
import { CATEGORIES } from '../content/config';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'いつものコードを、たまには読み物として。' } = Astro.props;
const siteTitle = 'tech-blog';
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;

// Left unset until AdSense approval; when set, BaseLayout loads the
// AdSense loader script once, site-wide.
const adsenseClientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    {adsenseClientId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`}
        crossorigin="anonymous"
      ></script>
    )}
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/"><strong>{siteTitle}</strong></a>
        {CATEGORIES.map((c) => (
          <a href={`/category/${c}/`}>{c}</a>
        ))}
        <a href="/about/">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-nav">
        <span>&copy; {new Date().getFullYear()} tech-blog</span>
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>
  </body>
</html>
